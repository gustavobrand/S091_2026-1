{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Virtual Desktop",
      "type": "shell",
      "command": "bash",
      "args": [
        ".devcontainer/start-desktop.sh"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "type": "java (buildArtifact)",
      "mainClass": "Main",
      "targetPath": "${workspaceFolder}/${workspaceFolderBasename}.jar",
      "elements": [
        "${compileOutput}",
        "${dependencies}"
      ],
      "problemMatcher": [],
      "label": "java (buildArtifact): APS-T1"
    }
  ]
}